HOST="localhost" # string (default: localhost)
PORT=4000 # number (default: 4000)
CORS_ORIGINS="true" # string: "true" to allow any origin, or comma-separated origins

## -----
# DATABASE (PostgreSQL)
DATABASE_URL=""
SKIP_DATABASE_CONNECT=false

## -----
# AUTH (JWT)
JWT_SECRET="change-this-to-a-long-secret"
JWT_EXPIRES_IN="7d" # examples: 1d | 7d | 30d | 12h

## -----
# EMAIL (optional, only needed if you enable the mailer integration)
EMAIL_HOST=""
EMAIL_USERNAME=""
EMAIL_PASSWORD=""
